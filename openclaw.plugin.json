{
  "id": "figma-designer",
  "logo": "./figma-plugin/assets/logo.jpeg",
  "configSchema": {
    "type": "object",
    "properties": {
      "personalAccessToken": {
        "type": "string",
        "description": "Figma Personal Access Token (with file_content:read scope)"
      },
      "bridgePort": {
        "type": "number",
        "description": "WebSocket port for the Figma plugin bridge (default: 3055)"
      }
    }
  },
  "uiHints": {
    "personalAccessToken": {
      "label": "Figma Personal Access Token",
      "sensitive": true,
      "placeholder": "figd_xxxxxxxxxxxx"
    },
    "bridgePort": {
      "label": "Figma Bridge Port",
      "placeholder": "3055"
    }
  }
}
